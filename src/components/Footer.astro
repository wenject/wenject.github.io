---
import { profileConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
const startDate = "2025-01-01";
---

<div class="my-10 mx-16">
    <div class="gradient-line"></div>
</div>
<div class="transition rounded-2xl mb-12 flex flex-col items-center justify-center px-6 gap-3">
    <div class="flex items-center gap-3 text-sm text-black/40 dark:text-white/40 transition">
        <a class="transition link text-[var(--primary)] font-medium hover:text-[var(--primary)]" target="_blank" href={url('rss.xml')}>RSS</a>
        <span class="text-black/15 dark:text-white/15">|</span>
        <a class="transition link text-[var(--primary)] font-medium hover:text-[var(--primary)]" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a>
    </div>

    <div class="flex items-center gap-2 text-xs text-black/30 dark:text-white/30 transition">
        <span>&copy; {currentYear} {profileConfig.name}</span>
        <span>·</span>
        <span>本站已运行 <span id="site-uptime" class="text-[var(--primary)] font-medium"></span></span>
    </div>

    <div class="text-xs text-black/20 dark:text-white/20 transition">
        Powered by
        <a class="transition link text-black/30 dark:text-white/30 hover:text-[var(--primary)]" target="_blank" href="https://astro.build">Astro</a> &
        <a class="transition link text-black/30 dark:text-white/30 hover:text-[var(--primary)]" target="_blank" href="https://github.com/saicaca/fuwari">Fuwari</a>
    </div>
</div>

<script is:inline define:vars={{startDate}}>
function updateUptime() {
    const start = new Date(startDate);
    const now = new Date();
    const diff = now.getTime() - start.getTime();
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const el = document.getElementById('site-uptime');
    if (el) el.textContent = days + ' 天 ' + hours + ' 时 ' + minutes + ' 分';
}
updateUptime();
setInterval(updateUptime, 60000);
</script>
