---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
---
<div class="card-base overflow-hidden relative group/profile">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/5 via-transparent to-[oklch(0.80_0.12_calc(var(--hue)+60))]/5 transition-opacity duration-500"></div>

    <div class="h-20 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/80 via-[oklch(0.78_0.08_calc(var(--hue)+40))] to-[oklch(0.85_0.06_80)]
                    dark:from-[var(--primary)]/30 dark:via-[oklch(0.30_0.04_calc(var(--hue)+40))] dark:to-[oklch(0.25_0.03_80)]"></div>
        <div class="absolute inset-0 opacity-20 dark:opacity-30">
            <div class="absolute w-32 h-32 rounded-full bg-white/30 dark:bg-[var(--primary)]/40 -top-16 -right-8 blur-2xl"></div>
            <div class="absolute w-24 h-24 rounded-full bg-white/20 dark:bg-[var(--primary)]/20 -bottom-12 -left-4 blur-xl"></div>
        </div>
    </div>

    <div class="px-5 pb-5 relative -mt-12">
        <a aria-label="Go to About Page" href={url('/about/')}
           class="group block relative mx-auto mb-3 w-24 h-24">
            <div class="absolute -inset-1 rounded-full bg-gradient-to-br from-[var(--primary)]/60 to-[oklch(0.82_0.08_80)]/60
                        dark:from-[var(--primary)]/40 dark:to-[oklch(0.40_0.06_80)]/40
                        opacity-50 blur-md group-hover:opacity-80 transition-all duration-700"></div>
            <div class="relative rounded-full p-[2px] bg-gradient-to-br from-[var(--primary)] to-[oklch(0.82_0.08_80)]
                        dark:from-[var(--primary)]/80 dark:to-[oklch(0.45_0.06_80)]/80">
                <div class="w-full h-full rounded-full overflow-hidden bg-[var(--card-bg)] ring-2 ring-[var(--card-bg)]">
                    <ImageWrapper src={config.avatar || ""} alt="Profile Image" class="w-full h-full object-cover rounded-full"></ImageWrapper>
                </div>
            </div>
            <div class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300
                        bg-black/25 flex items-center justify-center backdrop-blur-[2px]">
                <Icon name="fa6-regular:address-card" class="text-white text-xl drop-shadow-lg"></Icon>
            </div>
        </a>

        <div class="text-center relative">
            <div class="font-bold text-xl mb-1 dark:text-neutral-50 transition gradient-text inline-block">{config.name}</div>
            <div class="flex items-center justify-center gap-2 mb-2 mt-1">
                <div class="h-[1px] w-8 bg-gradient-to-r from-transparent to-[var(--primary)]/60"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[var(--primary)] animate-pulse"></div>
                <div class="h-[1px] w-8 bg-gradient-to-l from-transparent to-[var(--primary)]/60"></div>
            </div>
            <div class="text-sm text-neutral-400 mb-4 transition profile-bio">
                <span class="bio-text">{config.bio}</span>
            </div>
        </div>

        <div class="flex flex-wrap gap-2 justify-center">
            {config.links.length > 1 && config.links.map((item, i) =>
                <a rel="me" aria-label={item.name} href={item.url} target="_blank"
                   class="group/btn relative rounded-xl h-10 w-10 flex items-center justify-center
                          bg-[var(--btn-regular-bg)] text-[var(--btn-content)]
                          hover:-translate-y-1.5 active:scale-90
                          transition-all duration-300"
                   style={`transition-delay: ${i * 30}ms;`}>
                    <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-[var(--primary)] to-[oklch(0.80_0.12_calc(var(--hue)+60))]
                                opacity-0 group-hover/btn:opacity-100 transition-opacity duration-300"></div>
                    <Icon name={item.icon} class="text-[1.25rem] relative z-10 group-hover/btn:text-white transition-colors duration-300"></Icon>
                    <div class="absolute -inset-1 rounded-xl bg-[var(--primary)]/20 dark:bg-[var(--primary)]/30 opacity-0 group-hover/btn:opacity-100 blur-md transition-opacity duration-300"></div>
                </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name} href={config.links[0].url} target="_blank"
                                            class="btn-regular rounded-xl h-10 gap-2 px-4 font-bold active:scale-95
                                                   hover:bg-[var(--primary)] hover:text-white transition-all duration-300">
                <Icon name={config.links[0].icon} class="text-[1.25rem]"></Icon>
                {config.links[0].name}
            </a>}
        </div>
    </div>
</div>

<style>
    .profile-bio .bio-text {
        display: inline-block;
        overflow: hidden;
        white-space: nowrap;
        border-right: 2px solid var(--primary);
        animation: typing 2s steps(20) 0.8s forwards, blink-caret 0.7s step-end infinite;
        width: 0;
    }
    @keyframes typing {
        from { width: 0; }
        to { width: 100%; }
    }
    @keyframes blink-caret {
        from, to { border-color: transparent; }
        50% { border-color: var(--primary); }
    }
</style>
